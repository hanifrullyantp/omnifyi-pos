# Salin ke `.env.local` untuk `npm run dev` / build lokal.
# Di Vercel: Project Settings → Environment Variables (Production + Preview).

# URL Supabase Edge Function (atau endpoint Anda) untuk load/save konten landing & upload media.
# Kosongkan = konten hanya di browser (localStorage), cocok untuk demo offline.
VITE_CONTENT_EDGE_URL=

# Secret opsional; dikirim sebagai header `x-admin-secret` ke Edge Function (sesuaikan dengan fungsi Anda).
VITE_CONTENT_ADMIN_SECRET=
