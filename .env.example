# Salin file ini jadi `.env.local` untuk `npm run dev` / build lokal.
# Di Vercel: Project Settings → Environment Variables (Production + Preview).
#
# Panduan awam + Supabase / Midtrans / Resend: baca MANUAL_SETUP.md
# Template Edge Function CMS: folder supabase/functions/cms-landing/ di repo ini.

# URL Edge Function setelah deploy (contoh):
# https://XXXX.supabase.co/functions/v1/cms-landing
# Kosongkan = konten landing hanya di browser (localStorage).
VITE_CONTENT_EDGE_URL=

# Harus sama dengan: supabase secrets set CONTENT_ADMIN_SECRET="..."
# Dipakai header x-admin-secret dari admin landing.
VITE_CONTENT_ADMIN_SECRET=

# ===========================
# Supabase (POS Sync + Auth)
# ===========================
# Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Endpoint sync backend — lihat syncAdapter.ts (default: /api/sync/batch)
# VITE_SYNC_ENDPOINT=

# Jangan taruh Midtrans Server Key atau Resend API key di sini (bukan VITE_*).
