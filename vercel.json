{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "omnifyi.com" }],
      "destination": "/pos1",
      "permanent": true
    },
    {
      "source": "/dashboard/:path*",
      "has": [{ "type": "host", "value": "omnifyi.com" }],
      "destination": "https://pos.omnifyi.com/dashboard/:path*",
      "permanent": true
    },
    {
      "source": "/admin",
      "has": [{ "type": "host", "value": "omnifyi.com" }],
      "destination": "https://pos.omnifyi.com/admin",
      "permanent": true
    },
    {
      "source": "/kelola-sales-landing",
      "has": [{ "type": "host", "value": "omnifyi.com" }],
      "destination": "https://pos.omnifyi.com/kelola-sales-landing",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/((?!api/|assets/|favicon\\.ico|manifest\\.json|sw\\.js|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
